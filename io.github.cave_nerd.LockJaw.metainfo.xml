<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.cave_nerd.LockJaw</id>
  <name>Lock Jaw</name>
  <summary>Fast, local-first markdown note-taking</summary>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>

  <description>
    <p>
      Lock Jaw is a local-first markdown note-taking app built with Rust and egui.
      Notes are stored as plain .md files in a vault directory you choose —
      no accounts, no cloud dependency, no lock-in.
    </p>
    <p>Features include:</p>
    <ul>
      <li>Live split editor and preview pane</li>
      <li>Folder sections with collapsible tree navigation</li>
      <li>Multiple built-in themes including dark and light modes</li>
      <li>Optional WebDAV sync for self-hosted note backup</li>
      <li>WASM plugin system for extensibility</li>
      <li>Fuzzy search across all notes</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.github.cave_nerd.LockJaw.desktop</launchable>

  <url type="homepage">https://github.com/cave-nerd/lock-jaw</url>
  <url type="vcs-browser">https://github.com/cave-nerd/lock-jaw</url>
  <url type="bugtracker">https://github.com/cave-nerd/lock-jaw/issues</url>

  <screenshots>
    <screenshot type="default">
      <caption>Editor and live preview side by side</caption>
      <image type="source" width="1248" height="702">https://raw.githubusercontent.com/cave-nerd/lock-jaw/main/assets/screenshots/main.png</image>
    </screenshot>
  </screenshots>

  <categories>
    <category>Utility</category>
    <category>TextEditor</category>
  </categories>

  <keywords>
    <keyword>notes</keyword>
    <keyword>markdown</keyword>
    <keyword>editor</keyword>
    <keyword>vault</keyword>
    <keyword>local-first</keyword>
  </keywords>

  <provides>
    <binary>lockjaw</binary>
  </provides>

  <releases>
    <release version="0.1.0" date="2026-03-22">
      <description>
        <p>Initial release of Lock Jaw.</p>
        <ul>
          <li>Vault-based file management</li>
          <li>Split editor and live Markdown preview</li>
          <li>Dark and light themes</li>
          <li>WebDAV sync with OS keyring credential storage</li>
          <li>WASM plugin host</li>
        </ul>
      </description>
    </release>
  </releases>

  <content_rating type="oars-1.1"/>
</component>
